# Spoolify environment variables
# Copy this file to .env and set your values
SPOOLIFY_DB_FILE=spoolify.db

# API server
SPOOLIFY_API_HOST=0.0.0.0
SPOOLIFY_API_PORT=8000

# Logging
# SPOOLIFY_LOG_LEVEL=INFO        # DEBUG, INFO, WARNING, ERROR (default: INFO)
# SPOOLIFY_LOG_FILE=spoolify.log # Omit to log to stderr only (rotating, 10 MB × 5)

# Import path restriction
# SPOOLIFY_IMPORT_BASE=C:\Users\you  # Import paths must be inside this directory (default: home dir)
